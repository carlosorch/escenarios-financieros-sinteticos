{
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
    "*.snm",
    "*.synctex(busy)",
    "*.synctex.gz(busy)",
    "*.nav",
    "*.vrb",
    "*.gz",
    "*.bcf",
    "*.nlo",
    "*.run.xml"
  ],
  "latex-workshop.latex.outDir": "./PDF",
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.build.forceRecipeUsage": false,
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.clean.subfolder.enabled": true,
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.tools": [
    {
      "name": "docker_latexmk",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-v",
        "%DIR%:/work",
        "-w",
        "/work",
        "sanjibsen/weblatex:latest",
        "latexmk",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=PDF",
        "%DOCFILE%"
      ]
    },
    {
      "name": "docker_latexmk_xelatex",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-v",
        "%DIR%:/work",
        "-w",
        "/work",
        "sanjibsen/weblatex:latest",
        "latexmk",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-xelatex",
        "-outdir=PDF",
        "%DOCFILE%"
      ]
    },
    {
      "name": "latexmk_local",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=PDF",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk_local_xelatex",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-xelatex",
        "-outdir=PDF",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "docker_latexmk (recommended)",
      "tools": [
        "docker_latexmk"
      ]
    },
    {
      "name": "docker_latexmk_xelatex",
      "tools": [
        "docker_latexmk_xelatex"
      ]
    },
    {
      "name": "latexmk_local",
      "tools": [
        "latexmk_local"
      ]
    },
    {
      "name": "latexmk_local_xelatex",
      "tools": [
        "latexmk_local_xelatex"
      ]
    }
  ],
  "latex-workshop.view.pdf.color.dark.pageColorsBackground": "#171717",
  "latex-workshop.view.pdf.color.dark.pageColorsForeground": "#FFFFFF",
  "latex-workshop.view.pdf.color.dark.backgroundColor": "#171717",
  "editor.formatOnSave": true,
  "latex-workshop.latex.pdfWatch.delay": 500,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "grammarly.files.include": [
    "**/*.tex"
  ],
  "grammarly.files.exclude": [
    "**/*.md"
  ],
  "grammarly.selectors": [
    {
      "language": "latex",
      "scheme": "file"
    }
  ]
}
