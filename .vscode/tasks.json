{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup local thesis environment",
      "type": "shell",
      "command": "./scripts/setup-local.sh",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\setup-local-windows.ps1"
        ]
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Compile thesis PDF",
      "type": "shell",
      "command": "./scripts/compile-local.sh",
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder}\\scripts\\compile-local-windows.ps1"
        ]
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Compile thesis PDF (Docker fallback)",
      "type": "shell",
      "command": "docker run --rm -v \"${workspaceFolder}\":/work -w /work sanjibsen/weblatex:latest latexmk -pdf -interaction=nonstopmode -file-line-error -outdir=PDF plantilla.tex",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
