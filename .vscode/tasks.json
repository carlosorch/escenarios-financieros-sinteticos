{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile thesis PDF (Docker)",
      "type": "shell",
      "command": "docker run --rm -v \"${workspaceFolder}\":/work -w /work sanjibsen/weblatex:latest latexmk -pdf -interaction=nonstopmode -file-line-error -outdir=PDF plantilla.tex",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
